---
import Link from "./ui/link.astro";
import { getMessages, localizePath, type Locale } from "@/i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = getMessages(locale);
---

<div
  id="launch"
  class="bg-black p-8 md:px-20 md:py-20 mt-20 mx-auto max-w-5xl rounded-lg flex flex-col items-center text-center scroll-mt-24">
  <h2 class="text-white text-4xl md:text-6xl tracking-tight">
    {copy.cta.title}
  </h2>
  <p class="text-slate-400 mt-4 text-lg md:text-xl">
    {copy.cta.description}
  </p>
  <div class="flex mt-5">
    <Link href={localizePath("/contact", locale)} style="inverted">{copy.cta.button}</Link>
  </div>
</div>
