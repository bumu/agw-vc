---
import Container from "@/components/container.astro";
import Link from "@/components/ui/link.astro";
import {
  getAlternateLocalePath,
  getMessages,
  localizePath,
  type Locale,
} from "@/i18n";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = getMessages(locale);

const menuitems = [
  {
    title: copy.navbar.programs,
    path: localizePath("/#programs", locale),
  },
  {
    title: copy.navbar.about,
    path: localizePath("/about", locale),
  },
  {
    title: copy.navbar.contact,
    path: localizePath("/contact", locale),
  },
  {
    title: copy.navbar.launch,
    path: localizePath("/#launch", locale),
  },
];

const localeSwitchPath = getAlternateLocalePath(Astro.url.pathname, locale === "zh" ? "en" : "zh");
---

<Container>
  <header class="flex flex-col lg:flex-row justify-between items-center my-5">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <a href={localizePath("/", locale)} class="text-lg leading-tight"
          ><div><span class="font-bold text-slate-800">AGW</span><span
              class="text-slate-500"> VC</span
            ></div>
            <div class="hidden sm:block text-[11px] text-slate-500">
              {copy.navbar.brandMeaning}
            </div>
        </a>
        <div class="block lg:hidden">
          <MenuIcon class="w-4 h-4 text-gray-800" />
        </div>
      </div>
      <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
        <ul class="flex flex-col lg:flex-row lg:gap-3">
          {
            menuitems.map((item) => (
              <li>
                <a
                  href={item.path}
                  class="flex lg:px-3 py-2 items-center text-gray-600 hover:text-gray-900">
                  <span>{item.title}</span>
                </a>
              </li>
            ))
          }
        </ul>
        <div class="lg:hidden flex items-center mt-3 gap-4">
          <Link href={localeSwitchPath} style="muted" size="md">
            {copy.navbar.localeLabel}
          </Link>
          <Link href={localizePath("/contact", locale)} size="md" block>
            {copy.navbar.cta}
          </Link>
        </div>
      </MenuItems>
    </Astronav>
    <div>
      <div class="hidden lg:flex items-center gap-4">
        <Link href={localeSwitchPath} style="muted" size="md">
          {copy.navbar.localeLabel}
        </Link>
        <Link href={localizePath("/contact", locale)} size="md">
          {copy.navbar.cta}
        </Link>
      </div>
    </div>
  </header>
</Container>
