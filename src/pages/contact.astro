---
import Contactform from "@/components/contactform.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import Layout from "@/layouts/Layout.astro";
import { defaultLocale, getMessages } from "@/i18n";
import { Icon } from "astro-icon/components";

const locale = defaultLocale;
const copy = getMessages(locale);
---

<Layout title={copy.contact.pageTitle} locale={locale}>
  <Container>
    <Sectionhead>
      <Fragment slot="title">{copy.contact.sectionTitle}</Fragment>
      <Fragment slot="desc">{copy.contact.sectionDesc}</Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-16">
      <div>
        <h2 class="font-medium text-2xl text-gray-800">{copy.contact.heading}</h2>
        <p class="text-lg leading-relaxed text-slate-500 mt-3">
          {copy.contact.body}
        </p>
        <div class="mt-5">
          <div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:map-marker" />
            <span>{copy.contact.location}</span>
          </div><div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:envelope" /><a
              href="mailto:dean@airdb.com"
              >dean@airdb.com</a
            >
          </div><div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:phone" /><a
              href="tel:+65-0000-0000">+65 0000 0000</a
            >
          </div>
        </div>
      </div>
      <div>
        <Contactform locale={locale} />
      </div>
    </div>
  </Container>
</Layout>
